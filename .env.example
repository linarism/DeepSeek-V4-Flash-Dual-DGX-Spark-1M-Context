# =============================================================================
# DeepSeek V4 Flash – Dual DGX Spark Environment Configuration
# =============================================================================
# Copy this file to .env and edit the values to match your setup.
#
#   cp .env.example .env
#
# =============================================================================

# Node rank: 0 for head node, 1 for worker node
NODE_RANK=0

# Set to "1" to run in headless mode (worker node only)
HEADLESS=

# IP address of the head/master node (spark1)
MASTER_ADDR=169.254.109.196

# IP/hostname of the worker node (spark2) — used by start/stop scripts
WORKER_HOST=169.254.122.228

# HuggingFace cache directory (local path on each node)
HF_CACHE=${HOME}/.cache/huggingface

# InfiniBand interface (run `ibdev2netdev -v` to find yours)
NCCL_IB_HCA=rocep1s0f1

# Network interface for NCCL socket communication
NCCL_SOCKET_IFNAME=enp1s0f1np1
